# Copy to ai-dev-os.local.yaml (gitignored) — only if env:AI_DEV_OS_HOME is not enough.
# Usually you only need: export AI_DEV_OS_HOME=... in ~/.zshrc or ~/.bashrc
#
# ai_dev_os_home: /Users/you/ai-development-system
# project_root: /Users/you/projects/auction
#
# task_run:
#   agent: agy   # grok | agy — server AFK task manager
#
# Local read-only codebase survey (Mac interactive — optional; Ubuntu AFK: leave disabled)
# M2: omit block → auto-enable when `ollama` is on PATH; set enabled: false to force off.
# local_survey:
#   enabled: true
#   ollama_model: qwen2.5-coder:14b
#   ollama_host: http://127.0.0.1:11434
#
# Run observability — Mac watches Ubuntu AFK via SSH (see docs/USAGE-FEEDBACK.md)
# observe:
#   remote_host: ubuntu-afk
#   remote_project_root: ~/projects/my-app